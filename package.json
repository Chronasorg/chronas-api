{
  "name": "chronas-api",
  "version": "1.3.40",
  "description": "This API provides authentication and CRUD operations for data used by the Chronas application",
  "main": "lambda-handler.js",
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "engineStrict": false,
  "scripts": {
    "lint": "eslint *.js server config --fix",
    "test": "cross-env NODE_ENV=test mocha --require server/tests/helpers.js --reporter spec --colors server/tests --recursive --exit",
    "test:coverage": "cross-env NODE_ENV=test c8 mocha --require server/tests/helpers.js server/tests --recursive --exit",
    "test:check-coverage": "npm run test:coverage && c8 check-coverage",
    "test:postman:dev": "node scripts/run-postman-tests.js dev enhanced",
    "test:postman:prod": "node scripts/run-postman-tests.js prod enhanced",
    "test:setup": "node scripts/setup-test-environment.js",
    "validate:religion": "node scripts/data-validation/validate-religion.js",
    "validate:culture": "node scripts/data-validation/validate-religion.js --dimension culture",
    "validate:scan": "node scripts/data-validation/scan-dimension.js",
    "validate:apply": "node scripts/data-validation/apply-corrections.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/daumann/chronas-api.git"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-secrets-manager": "^3.1035.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "@vendia/serverless-express": "4.12.6",
    "aws-xray-sdk": "^3.5.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "express-jwt": "8.5.1",
    "express-rate-limit": "8.5.1",
    "express-session": "^1.18.2",
    "express-validation": "4.1.1",
    "express-winston": "^4.0.4",
    "helmet": "^8.0.0",
    "http-status": "^2.0.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.0",
    "memory-cache": "0.2.0",
    "method-override": "^3.0.0",
    "moniker": "0.1.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.5",
    "nodemailer-mailgun-transport": "2.1.5",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github": "^1.1.0",
    "passport-google-oauth": "2.0.0",
    "sanitize-html": "2.17.3",
    "swagger-ui-express": "5.0.1",
    "winston": "^3.8.0",
    "yamljs": "0.3.0"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "follow-redirects": "^1.16.0",
    "handlebars": "^4.7.9",
    "ip-address": "^10.1.1",
    "lodash": "^4.18.1",
    "node-forge": "^1.4.0",
    "qs": "^6.14.1",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "c8": "^11.0.0",
    "chai": "^6.0.0",
    "cross-env": "^10.0.0",
    "dynalite": "4.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-promise": "^7.0.0",
    "globals": "^16.0.0",
    "mocha": "^11.0.0",
    "newman": "6.2.2",
    "supertest": "^7.0.0"
  },
  "bugs": {
    "url": "https://github.com/daumann/chronas-api/issues"
  }
}
