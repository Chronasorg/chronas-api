# Test Environment Configuration
#
# Loaded by config/config.js when NODE_ENV=test (i.e. via `npm test`).
# server/tests/helpers.js sets the DynamoDB feature flags directly so the
# test suite runs against dynalite (in-memory DynamoDB) without contacting
# any AWS service.

NODE_ENV=test
PORT=3001

JWT_SECRET=test-jwt-secret-key
