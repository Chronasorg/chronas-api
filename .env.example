# Chronas API Environment Configuration
#
# Local development uses a `.env` file (gitignored). In Lambda the same
# values come either from `process.env.chronasConfig` (a JSON blob set by
# infra/apply-lambda-config.sh) or from AWS Secrets Manager
# (`SECRET_CONFIG_NAME=/chronas/secrets`).

# --- Required ---

# JWT signing secret. Required in all environments.
JWT_SECRET=your-super-secret-jwt-key-change-this

# --- Application ---

NODE_ENV=development
PORT=4040

# --- AWS ---

# Region the AWS SDK clients use. Defaults to eu-west-1 if unset.
AWS_REGION=eu-west-1

# --- DynamoDB feature flags ---
# All defaults to true; set to false locally only if you need to disable
# a specific table during debugging.
USE_DYNAMODB_AREAS=true
USE_DYNAMODB_MARKERS=true
USE_DYNAMODB_METADATA=true
USE_DYNAMODB_USERS=true
USE_DYNAMODB_FLAGS=true
USE_DYNAMODB_REVISIONS=true
USE_DYNAMODB_BOARD=true
DYNAMODB_TABLE_PREFIX=chronas

# --- CORS ---
# All https://*.chronas.org subdomains are allowed automatically by regex.
# Use ALLOWED_ORIGINS to add extra non-chronas.org origins (comma-separated).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Frontend ---
# Public host used in OAuth redirects and email links.
CHRONAS_HOST=https://chronas.org

# --- OAuth (optional, only needed if exercising auth flows locally) ---

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# --- Mail (optional) ---

MAILGUN_KEY=
MAILGUN_DOMAIN=
MAILGUN_RECEIVER=

# --- Image hosting / payment / RUM (optional) ---

CLOUDINARY_URL=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

RUMENDPOINT=
RUMROLEARN=
RUMIDENTITYPOOL=
RUMAPPLICATIONID=
